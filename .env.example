# 실제 키는 .env 에 넣고 절대 커밋하지 않는다(.gitignore 처리).
# Kraken API 키: query + trade 권한만, 출금/펀딩 권한 OFF. 가능하면 VM IP 로 제한.
KRAKEN_API_KEY=your_key_here
KRAKEN_API_SECRET=your_secret_here

# Telegram (옵션)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# live 실거래 이중 가드의 환경변수 쪽. live 전환 시에만 정확히 이 값으로 설정.
JUNE_BOT_ALLOW_LIVE=
